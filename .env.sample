# ─────────────────────────────────────────────────────────────────────────────
# DocuBridge AI — LIVE TEST config (local only)
#
# IMPORTANT: This app is a pure frontend SPA with NO backend and NO build step.
# Nothing here is read by the app at runtime — real settings live in IndexedDB
# (BYOK, entered via the Settings screen). This file exists ONLY so you can hand
# the agent a key + model for an agent-driven live test without typing the key
# into a field. The agent reads `.env`, loads these into the preview browser's
# IndexedDB, runs a real extraction on a doc from _live_test/, then clears the key.
#
# 1. Copy this file to `.env`  (cp .env.sample .env)
# 2. Fill in the values below.
# 3. `.env` is git-ignored — your real key is NEVER committed.
# 4. Drop a test document into the _live_test/ folder.
# 5. Tell the agent the filename and say "run the live test".
# ─────────────────────────────────────────────────────────────────────────────

# Which provider to test: gemini | openai
PROVIDER=gemini

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Examples: gemini-3.1-flash-lite, gemini-3.5-flash, gemini-3-pro
GEMINI_MODEL=gemini-3.1-flash-lite
# Thinking intensity (NOT a token budget). low | medium | high
# NOTE: the app currently FORCES thinkingLevel=low for any gemini-3* model in
# code; this var documents intent and lets the test override it.
GEMINI_THINKING_LEVEL=low

# ── OpenAI (only if PROVIDER=openai) ─────────────────────────────────────────
OPENAI_API_KEY=
# Examples: gpt-5.4-mini, gpt-5.4
OPENAI_MODEL=gpt-5.4-mini
# Reasoning effort. low | medium | high
# NOTE: the app currently FORCES reasoning_effort=low for any gpt-5* model.
OPENAI_REASONING_EFFORT=low
